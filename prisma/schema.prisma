// Prisma schema – PostgreSQL
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   // Spotify user id
  userName     String?
  userEmail    String?
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@map("sessions")
}

model TrackedPlaylist {
  id                String             @id @default(cuid())
  userId            String             // Spotify user id uit sessie
  spotifyPlaylistId String
  name              String
  description       String?
  ownerName         String
  imageUrl          String?
  snapshotId        String?
  trackCount        Int                @default(0)
  followerCount     Int                @default(0)
  isPublic          Boolean            @default(true)
  isCollaborative   Boolean            @default(false)
  lastSyncedAt      DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  snapshots         PlaylistSnapshot[]
  groupPlaylists    GroupPlaylist[]
  reportSources     ReportSource[]
  schedulerSources  SchedulerSource[]
  schedulerClockSlots SchedulerClockSlot[]
  schedulerOverlapPreferences SchedulerOverlapPreference[]

  @@unique([userId, spotifyPlaylistId])
  @@map("tracked_playlists")
}

model PlaylistGroup {
  id             String          @id @default(cuid())
  userId         String
  name           String
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  groupPlaylists GroupPlaylist[]
  reportSources  ReportSource[]
  schedulerSources SchedulerSource[]
  schedulerClockSlots SchedulerClockSlot[]
  schedulerOverlapPreferences SchedulerOverlapPreference[]

  @@unique([userId, name])
  @@map("playlist_groups")
}

model GroupPlaylist {
  id                String         @id @default(cuid())
  groupId           String
  trackedPlaylistId String
  createdAt         DateTime       @default(now())
  group             PlaylistGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  trackedPlaylist   TrackedPlaylist @relation(fields: [trackedPlaylistId], references: [id], onDelete: Cascade)

  @@unique([groupId, trackedPlaylistId])
  @@map("group_playlists")
}

enum SchedulerMode {
  clock
  ratio
}

enum SchedulerSelectionMode {
  random
  rank_preferred
}

enum SchedulerRuleType {
  artist_maximum
  artist_separation
  title_separation
}

enum SchedulerRunStatus {
  pending
  success
  failed
}

model PlaylistSnapshot {
  id                String         @id @default(cuid())
  trackedPlaylistId String
  spotifySnapshotId String
  syncedAt          DateTime       @default(now())
  trackedPlaylist   TrackedPlaylist @relation(fields: [trackedPlaylistId], references: [id], onDelete: Cascade)
  tracks            SnapshotTrack[]

  @@map("playlist_snapshots")
}

model SnapshotTrack {
  id                String           @id @default(cuid())
  snapshotId        String
  spotifyTrackId    String
  spotifyUri        String
  spotifyUrl        String
  title             String
  artistsJson       String           // JSON array of {name, id?}
  album             String
  durationMs        Int?             // Track lengte in ms
  position          Int              // 0-based index in playlist
  snapshot          PlaylistSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@map("snapshot_tracks")
}

model Report {
  id          String         @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sources     ReportSource[]
  results     ReportResult[]

  @@map("reports")
}

model Scheduler {
  id               String               @id @default(cuid())
  userId           String
  name             String
  description      String?
  mode             SchedulerMode
  targetTrackCount Int
  ratioEvenDistribution Boolean         @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  sources          SchedulerSource[]
  clockSlots       SchedulerClockSlot[]
  rules            SchedulerRule[]
  runs             SchedulerRun[]
  reference        SchedulerReference?
  overlapPreferences SchedulerOverlapPreference[]

  @@map("schedulers")
}

model SchedulerReference {
  id          String    @id @default(cuid())
  schedulerId String    @unique
  rowsJson    String    // JSON array of reference tracks (spotifyTrackId, title, …)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  scheduler   Scheduler @relation(fields: [schedulerId], references: [id], onDelete: Cascade)

  @@map("scheduler_references")
}

model SchedulerOverlapPreference {
  id                 String           @id @default(cuid())
  schedulerId        String
  trackedPlaylistId  String?
  playlistGroupId    String?
  overlapPercent     Int              @default(0)
  scheduler          Scheduler        @relation(fields: [schedulerId], references: [id], onDelete: Cascade)
  trackedPlaylist    TrackedPlaylist? @relation(fields: [trackedPlaylistId], references: [id], onDelete: Cascade)
  playlistGroup      PlaylistGroup?   @relation(fields: [playlistGroupId], references: [id], onDelete: Cascade)

  @@unique([schedulerId, trackedPlaylistId])
  @@unique([schedulerId, playlistGroupId])
  @@map("scheduler_overlap_preferences")
}

model SchedulerSource {
  id                String                 @id @default(cuid())
  schedulerId       String
  trackedPlaylistId String?
  playlistGroupId   String?
  include           Boolean                @default(true)
  weight            Float?
  selectionMode     SchedulerSelectionMode @default(rank_preferred)
  rankBiasStrength  Int?
  scheduler         Scheduler              @relation(fields: [schedulerId], references: [id], onDelete: Cascade)
  trackedPlaylist   TrackedPlaylist?       @relation(fields: [trackedPlaylistId], references: [id], onDelete: Cascade)
  playlistGroup     PlaylistGroup?         @relation(fields: [playlistGroupId], references: [id], onDelete: Cascade)

  @@map("scheduler_sources")
}

model SchedulerClockSlot {
  id                String           @id @default(cuid())
  schedulerId       String
  position          Int
  trackedPlaylistId String?
  playlistGroupId   String?
  spotifyTrackId    String?
  scheduler         Scheduler        @relation(fields: [schedulerId], references: [id], onDelete: Cascade)
  trackedPlaylist   TrackedPlaylist? @relation(fields: [trackedPlaylistId], references: [id], onDelete: Cascade)
  playlistGroup     PlaylistGroup?   @relation(fields: [playlistGroupId], references: [id], onDelete: Cascade)

  @@unique([schedulerId, position])
  @@map("scheduler_clock_slots")
}

model SchedulerRule {
  id         String            @id @default(cuid())
  schedulerId String
  ruleType   SchedulerRuleType
  valueInt   Int?
  scheduler  Scheduler         @relation(fields: [schedulerId], references: [id], onDelete: Cascade)

  @@map("scheduler_rules")
}

model SchedulerRun {
  id          String            @id @default(cuid())
  schedulerId String
  createdAt   DateTime          @default(now())
  resultJson  String?
  editedResultJson String?
  status      SchedulerRunStatus
  scheduler   Scheduler          @relation(fields: [schedulerId], references: [id], onDelete: Cascade)

  @@map("scheduler_runs")
}

model ReportSource {
  id                String         @id @default(cuid())
  reportId          String
  trackedPlaylistId String?
  playlistGroupId  String?
  weight            Float          @default(1)
  include           Boolean        @default(true)
  report            Report         @relation(fields: [reportId], references: [id], onDelete: Cascade)
  trackedPlaylist   TrackedPlaylist? @relation(fields: [trackedPlaylistId], references: [id], onDelete: Cascade)
  playlistGroup     PlaylistGroup?  @relation(fields: [playlistGroupId], references: [id], onDelete: Cascade)

  @@map("report_sources")
}

model ReportResult {
  id             String   @id @default(cuid())
  reportId       String
  generatedAt    DateTime @default(now())
  rowsJson       String   // JSON array of chart rows (origineel)
  editedRowsJson Json?    // handmatig bewerkte versie; rowsJson blijft ongewijzigd
  report         Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_results")
}
