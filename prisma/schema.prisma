// Prisma schema – PostgreSQL
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   // Spotify user id
  userName     String?
  userEmail    String?
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@map("sessions")
}

model TrackedPlaylist {
  id                String             @id @default(cuid())
  userId            String             // Spotify user id uit sessie
  spotifyPlaylistId String
  name              String
  description       String?
  ownerName         String
  imageUrl          String?
  snapshotId        String?
  trackCount        Int                @default(0)
  isPublic          Boolean            @default(true)
  isCollaborative   Boolean            @default(false)
  lastSyncedAt      DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  snapshots         PlaylistSnapshot[]
  groupPlaylists    GroupPlaylist[]
  reportSources     ReportSource[]

  @@unique([userId, spotifyPlaylistId])
  @@map("tracked_playlists")
}

model PlaylistGroup {
  id             String          @id @default(cuid())
  userId         String
  name           String
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  groupPlaylists GroupPlaylist[]
  reportSources  ReportSource[]

  @@unique([userId, name])
  @@map("playlist_groups")
}

model GroupPlaylist {
  id                String         @id @default(cuid())
  groupId           String
  trackedPlaylistId String
  createdAt         DateTime       @default(now())
  group             PlaylistGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  trackedPlaylist   TrackedPlaylist @relation(fields: [trackedPlaylistId], references: [id], onDelete: Cascade)

  @@unique([groupId, trackedPlaylistId])
  @@map("group_playlists")
}

model PlaylistSnapshot {
  id                String         @id @default(cuid())
  trackedPlaylistId String
  spotifySnapshotId String
  syncedAt          DateTime       @default(now())
  trackedPlaylist   TrackedPlaylist @relation(fields: [trackedPlaylistId], references: [id], onDelete: Cascade)
  tracks            SnapshotTrack[]

  @@map("playlist_snapshots")
}

model SnapshotTrack {
  id                String           @id @default(cuid())
  snapshotId        String
  spotifyTrackId    String
  spotifyUri        String
  spotifyUrl        String
  title             String
  artistsJson       String           // JSON array of {name, id?}
  album             String
  position          Int              // 0-based index in playlist
  snapshot          PlaylistSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@map("snapshot_tracks")
}

model Report {
  id          String         @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sources     ReportSource[]
  results     ReportResult[]

  @@map("reports")
}

model ReportSource {
  id                String         @id @default(cuid())
  reportId          String
  trackedPlaylistId String?
  playlistGroupId  String?
  weight            Float          @default(1)
  include           Boolean        @default(true)
  report            Report         @relation(fields: [reportId], references: [id], onDelete: Cascade)
  trackedPlaylist   TrackedPlaylist? @relation(fields: [trackedPlaylistId], references: [id], onDelete: Cascade)
  playlistGroup     PlaylistGroup?  @relation(fields: [playlistGroupId], references: [id], onDelete: Cascade)

  @@map("report_sources")
}

model ReportResult {
  id             String   @id @default(cuid())
  reportId       String
  generatedAt    DateTime @default(now())
  rowsJson       String   // JSON array of chart rows (origineel)
  editedRowsJson String?  // handmatig bewerkte versie; rowsJson blijft ongewijzigd
  report         Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_results")
}
